{
    "name": "nahid/laravel-ai-notes",
    "description": "AI-powered voice notes with semantic search for Laravel",
    "type": "library",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0 || ^12.0 || ^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Nahid\\AINotesPackage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nahid\\AINotesPackage\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Nahid\\AINotesPackage\\AINotesServiceProvider"],
            "aliases": {"AINote": "Nahid\\AINotesPackage\\Facades\\AINote"}
        }
    }
}